# Copy to e2e/.env (gitignored) for local e2e runs.

# Foundry license key (24-char) — activated fresh for the e2e container hostname.
# Local: your dev license. CI: a repo secret.
FOUNDRY_LICENSE_KEY=

# Optional: path to a cached Foundry binary so boot skips the download (no
# foundryvtt.com creds needed). Default = the local dev cache (see compose.yml).
# FOUNDRY_CACHE_DIR=../../../.dev-state/cfg_user_storage/platform/foundry/cache

# Optional: host port the wrapper's :30000 is published on (must match
# E2E_FOUNDRY_PORT used by playwright.config.ts). Default 30001.
# E2E_FOUNDRY_PORT=30001
